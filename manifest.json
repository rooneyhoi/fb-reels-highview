{
  "manifest_version": 3,
  "name": "FB Reels High View Extractor",
  "version": "1.0.1",
  "description": "Scan Facebook Reels on a page and list reels with high views.",

  "icons": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["scripting", "activeTab", "tabs"],
  "host_permissions": ["https://www.facebook.com/*"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan Reels",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    }
  }
}
