{
  "manifest_version": 3,
  "name": "FB Reels High View Extractor",
  "version": "1.0.1",
  "description": "Scan Facebook Reels on a page and list reels with high views.",
  "permissions": ["scripting", "activeTab", "tabs"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan Reels"
  }
}